client
dev tun
proto udp
pull
remote jinbay.vpnserver.global 123

resolv-retry infinite
nobind
persist-key
persist-tun
explicit-exit-notify 5
reneg-sec 0
setenv CLIENT_CERT 0

tun-mtu 1280
mssfix 1280

key-direction 1

